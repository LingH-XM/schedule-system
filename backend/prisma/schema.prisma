generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id           String   @id @default(cuid())
  accountId    String   @unique
  name         String
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastActiveAt DateTime @default(now())
}

model User {
  id           String   @id @default(cuid())
  accountId    String
  username     String   @unique
  phone        String?  @unique
  passwordHash String
  name         String
  role         String
  isActive     Boolean  @default(true)
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastLoginAt  DateTime?

  @@index([accountId])
}

model Snapshot {
  id        String   @id @default(cuid())
  accountId String   @default("default")
  profile   String
  planId    String
  resource  String
  payload   Json
  savedAt   DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([accountId, profile, planId, resource])
  @@index([accountId, profile, resource])
}

model Teacher {
  pk                  String               @id @default(cuid())
  accountId           String               @default("default")
  profile             String
  planId              String
  teacherId           String
  name                String
  campusId            String
  subject             String
  subjectGroup        String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  teachingAssignments TeachingAssignment[]

  @@unique([accountId, profile, planId, teacherId])
  @@index([accountId, profile, planId, campusId])
  @@index([accountId, profile, planId, name])
}

model Course {
  pk                  String               @id @default(cuid())
  accountId           String               @default("default")
  profile             String
  planId              String
  courseId            String
  name                String
  shortName           String
  subject             String
  campusId            String               @default("")
  scopes              Json
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  teachingAssignments TeachingAssignment[]

  @@unique([accountId, profile, planId, courseId])
  @@index([accountId, profile, planId, subject])
}

model SchoolClass {
  pk                  String               @id @default(cuid())
  accountId           String               @default("default")
  profile             String
  planId              String
  classId             String
  campusId            String
  stage               String
  grade               String
  classNo             Int
  className           String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  teachingAssignments TeachingAssignment[]

  @@unique([accountId, profile, planId, classId])
  @@index([accountId, profile, planId, campusId, grade])
  @@index([accountId, profile, planId, className])
}

model TeachingAssignment {
  pk            String      @id @default(cuid())
  accountId     String      @default("default")
  profile       String
  planId        String
  assignmentId  String
  campusId      String
  grade         String
  weeklyLessons Int
  classId       String
  teacherId     String
  courseId      String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  class         SchoolClass @relation(fields: [accountId, profile, planId, classId], references: [accountId, profile, planId, classId], onDelete: Cascade)
  course        Course      @relation(fields: [accountId, profile, planId, courseId], references: [accountId, profile, planId, courseId], onDelete: Cascade)
  teacher       Teacher     @relation(fields: [accountId, profile, planId, teacherId], references: [accountId, profile, planId, teacherId], onDelete: Cascade)

  @@unique([accountId, profile, planId, assignmentId])
  @@index([accountId, profile, planId, classId])
  @@index([accountId, profile, planId, teacherId])
  @@index([accountId, profile, planId, courseId])
}
