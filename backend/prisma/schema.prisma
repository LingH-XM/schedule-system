generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id           String   @id @default(cuid())
  schoolId     String   @unique @map("accountId")
  name         String
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastActiveAt DateTime @default(now())
  featureFlags Json     @default("{}")
  featureSettings Json  @default("{}")
  featureNotes String   @default("")
  users        User[]
}

model User {
  id           String   @id @default(cuid())
  schoolId     String   @map("accountId")
  username     String   @unique
  phone        String?  @unique
  passwordHash String
  name         String
  role         String   @default("school_admin")
  permissions  Json     @default("[]")
  mustChangePassword Boolean @default(true)
  createdByUserId String?
  isActive     Boolean  @default(true)
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastLoginAt  DateTime?
  school       Account  @relation(fields: [schoolId], references: [schoolId], onDelete: Restrict)
  scopes       UserScope[]
  createdBy    User?    @relation("UserCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdUsers User[]   @relation("UserCreator")

  @@index([schoolId])
  @@index([createdByUserId])
}

model UserScope {
  id       String @id @default(cuid())
  userId   String
  campusId String @default("*")
  grade    String @default("*")
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, campusId, grade])
  @@index([userId])
  @@index([campusId, grade])
}

model Snapshot {
  id        String   @id @default(cuid())
  schoolId  String   @default("default") @map("accountId")
  profile   String
  planId    String
  resource  String
  payload   Json
  savedAt   DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, profile, planId, resource])
  @@index([schoolId, profile, resource])
}

model Teacher {
  pk                  String               @id @default(cuid())
  schoolId            String               @default("default") @map("accountId")
  profile             String
  planId              String
  teacherId           String
  name                String
  campusId            String
  subject             String
  subjectGroup        String
  weeklyLessonRequirement Int                  @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  teachingAssignments TeachingAssignment[]

  @@unique([schoolId, profile, planId, teacherId])
  @@index([schoolId, profile, planId, campusId])
  @@index([schoolId, profile, planId, name])
}

model Course {
  pk                  String               @id @default(cuid())
  schoolId            String               @default("default") @map("accountId")
  profile             String
  planId              String
  courseId            String
  name                String
  shortName           String
  subject             String
  campusId            String               @default("")
  scopes              Json
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  teachingAssignments TeachingAssignment[]

  @@unique([schoolId, profile, planId, courseId])
  @@index([schoolId, profile, planId, subject])
}

model SchoolClass {
  pk                  String               @id @default(cuid())
  schoolId            String               @default("default") @map("accountId")
  profile             String
  planId              String
  classId             String
  campusId            String
  stage               String
  grade               String
  classNo             Int
  className           String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  teachingAssignments TeachingAssignment[]

  @@unique([schoolId, profile, planId, classId])
  @@index([schoolId, profile, planId, campusId, grade])
  @@index([schoolId, profile, planId, className])
}

model TeachingAssignment {
  pk            String      @id @default(cuid())
  schoolId      String      @default("default") @map("accountId")
  profile       String
  planId        String
  assignmentId  String
  campusId      String
  grade         String
  weeklyLessons Int
  classId       String
  teacherId     String
  courseId      String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  class         SchoolClass @relation(fields: [schoolId, profile, planId, classId], references: [schoolId, profile, planId, classId], onDelete: Cascade)
  course        Course      @relation(fields: [schoolId, profile, planId, courseId], references: [schoolId, profile, planId, courseId], onDelete: Cascade)
  teacher       Teacher     @relation(fields: [schoolId, profile, planId, teacherId], references: [schoolId, profile, planId, teacherId], onDelete: Cascade)

  @@unique([schoolId, profile, planId, assignmentId])
  @@index([schoolId, profile, planId, classId])
  @@index([schoolId, profile, planId, teacherId])
  @@index([schoolId, profile, planId, courseId])
}
